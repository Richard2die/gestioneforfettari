  { id:"P", label:"Informatica, ICT, software", codici:"62, 63", coeff:0.78 },
  { id:"Q", label:"Trasporto e magazzinaggio", codici:"49–53", coeff:0.67 },
  { id:"R", label:"Noleggio, agenzie viaggio, servizi alle imprese", codici:"77, 78, 79, 80, 81, 82", coeff:0.67 },
  { id:"S", label:"Servizi alla persona (estetisti, parrucchieri…)", codici:"96", coeff:0.67 },
