  { id:"U", label:"Promozione pubblicitaria, relazioni pubbliche", codici:"73", coeff:0.78 },
  { id:"V", label:"Studi legali, notarili, consulenza", codici:"69.1, 69.2", coeff:0.78 },
  { id:"W", label:"Medicina, odontoiatria, veterinaria", codici:"86.2, 75", coeff:0.78 },
  { id:"X", label:"Commercio autoveicoli e riparazioni", codici:"45.1, 45.2, 45.3, 45.4", coeff:0.40 },
  { id:"Y", label:"Distributori carburante", codici:"47.3", coeff:0.40 },
];

// Populate select
const sel = document.getElementById('ateco');
ATECO_DATA.forEach(a => {
  const o = document.createElement('option');
  o.value = a.id;
  o.textContent = `${(a.coeff*100).toFixed(0)}% — ${a.label}`;
  sel.appendChild(o);
});

// Populate table
const tbody = document.getElementById('atecoTableBody');
ATECO_DATA.forEach(a => {
  const imp = (50000 * a.coeff).toLocaleString('it-IT', {maximumFractionDigits:0});
  const tr = document.createElement('tr');
  tr.dataset.id = a.id;
  tr.innerHTML = `
    <td>${a.label}</td>
    <td class="codici-cell">${a.codici}</td>
    <td><span class="coeff-badge">${(a.coeff*100).toFixed(0)}%</span></td>
    <td style="font-family:'DM Mono',monospace;color:var(--text-lt)">€ ${imp}</td>
  `;
  tbody.appendChild(tr);
});

document.getElementById('ateco').addEventListener('change', function() {
  const a = ATECO_DATA.find(x => x.id === this.value);
  const box = document.getElementById('atecoInfo');
  if (a) {
    box.innerHTML = `Codici: <span class="val">${a.codici}</span>&ensp;·&ensp;Coefficiente: <span class="coeff-hi">${(a.coeff*100).toFixed(0)}%</span>&ensp;·&ensp;Su 50.000 €: <span class="val">€ ${(50000*a.coeff).toLocaleString('it-IT')}</span>`;
    document.querySelectorAll('tbody tr').forEach(r => r.classList.remove('hl'));
    const row = document.querySelector(`tbody tr[data-id="${a.id}"]`);
    if (row) { row.classList.add('hl'); row.scrollIntoView({behavior:'smooth', block:'nearest'}); }
  } else {
    box.innerHTML = 'Seleziona un codice ATECO per visualizzare il coefficiente.';
  }
});

function fmt(n) {
  return '€\u00a0' + n.toLocaleString('it-IT', {minimumFractionDigits:2, maximumFractionDigits:2});
}

function mkRow(lbl, val, isTot) {
  return `<div class="res-row${isTot?' tot':''}">
    <span class="lbl">${lbl}</span>
    <span class="val">${val}</span>
  </div>`;
}

function calcPeriodo(fatturato, coeff, gestione, isStartup) {
  const aliqImp = isStartup ? 0.05 : 0.15;
  const redditoBrutto = fatturato * coeff;
  let aliqCont = 0, minC = 0;
  if (gestione === 'gestione_separata') aliqCont = 0.2623;
  else if (gestione === 'artigiani')    { aliqCont = 0.24;   minC = 4515; }
  else if (gestione === 'commercianti') { aliqCont = 0.2448; minC = 4515; }
  const contributi = gestione !== 'altra_cassa' ? Math.max(redditoBrutto * aliqCont, minC) : 0;
  const reddImp = Math.max(0, redditoBrutto - contributi);
  const imposta = reddImp * aliqImp;
  const totale = imposta + contributi;
  const netto = fatturato - totale;
  return { redditoBrutto, contributi, reddImp, imposta, totale, netto };
}

function calcola() {
  const fatturato = parseFloat(document.getElementById('fatturato').value) || 0;
  const atecoId   = document.getElementById('ateco').value;
  const gestione  = document.getElementById('gestione').value;

  if (!fatturato || fatturato <= 0) { alert('Inserisci il fatturato lordo previsto.'); return; }
  if (!atecoId) { alert('Seleziona un codice ATECO.'); return; }
  if (fatturato > 85000) { alert('Il fatturato supera il limite di € 85.000 del regime forfettario.'); return; }

  const a = ATECO_DATA.find(x => x.id === atecoId);
  const su = calcPeriodo(fatturato, a.coeff, gestione, true);
  const re = calcPeriodo(fatturato, a.coeff, gestione, false);

  const gLabel = {
    gestione_separata:'Gest. Separata (26,23%)',
    artigiani:'Artigiani (24%)',
    commercianti:'Commercianti (24,48%)',
    altra_cassa:'Altra Cassa'
  }[gestione];

  function rows(d, pct) {
    return mkRow('Fatturato lordo', fmt(fatturato))
      + mkRow(`Reddito imponibile (coeff. ${(a.coeff*100).toFixed(0)}%)`, fmt(d.redditoBrutto))
      + mkRow(`Contributi — ${gLabel}`, fmt(d.contributi))
      + mkRow('Base imponibile (al netto contributi)', fmt(d.reddImp))
      + mkRow(`Imposta sostitutiva (${pct})`, fmt(d.imposta))
      + mkRow('Totale versamenti', fmt(d.totale))
      + mkRow('Reddito netto disponibile', fmt(d.netto), true);
  }

  document.getElementById('rowsStartup').innerHTML = rows(su, '5%');
  document.getElementById('rowsRegime').innerHTML  = rows(re, '15%');

  const cS = document.getElementById('cardStartup');
  const cR = document.getElementById('cardRegime');
  [cS, cR].forEach(c => c.classList.remove('show'));
  setTimeout(() => cS.classList.add('show'), 40);
  setTimeout(() => cR.classList.add('show'), 130);

  const diff = re.imposta - su.imposta;
  document.getElementById('savingAmount').textContent = fmt(diff);
  const banner = document.getElementById('savingBanner');
  banner.classList.remove('show');
  setTimeout(() => banner.classList.add('show'), 270);
}
</script>
