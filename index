<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Forfettario · Calcolatore Fiscale</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --navy-900: #0b1629;
    --navy-800: #0f1f3d;
    --navy-700: #152848;
    --navy-600: #1e3a5f;
    --navy-500: #2a5080;
    --navy-400: #3d6fa0;
    --orange:   #f05a1a;
    --orange-lt:#ff7d3f;
    --orange-bg:rgba(240,90,26,0.08);
    --orange-bd:rgba(240,90,26,0.25);
    --grey-100: #f5f7fa;
    --grey-200: #e8edf4;
    --grey-300: #cdd5e0;
    --grey-400: #9aaabb;
    --grey-500: #6b7f96;
    --white:    #ffffff;
    --text:     #1a2840;
    --text-lt:  #4a6080;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--grey-100);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    line-height: 1.5;
    min-height: 100vh;
  }

  /* TOP BAR */
  .topbar {
    background: var(--navy-800);
    padding: 0 2rem;
    height: 54px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 2px solid var(--orange);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .topbar-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--white);
    letter-spacing: 0.07em;
  }

  .topbar-dot {
    width: 7px; height: 7px;
    background: var(--orange);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .topbar-pill {
    background: var(--orange);
    color: #fff;
    font-size: 0.62rem;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.65rem;
    border-radius: 100px;
  }

  /* HERO */
  .hero {
    background: var(--navy-800);
    padding: 2.8rem 2rem 2.4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 55% 80% at 12% 50%, rgba(240,90,26,0.07) 0%, transparent 65%),
      radial-gradient(ellipse 50% 60% at 88% 30%, rgba(42,80,128,0.35) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--navy-500) 30%, var(--orange) 50%, var(--navy-500) 70%, transparent 100%);
  }

  .hero-eyebrow {
    display: inline-block;
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--orange-lt);
    margin-bottom: 0.9rem;
    position: relative;
  }

  .hero h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.9rem, 4.5vw, 3rem);
    color: var(--white);
    line-height: 1.1;
    position: relative;
    margin-bottom: 0.6rem;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--orange-lt);
  }

  .hero-sub {
    font-size: 0.85rem;
    color: var(--grey-400);
    position: relative;
    letter-spacing: 0.02em;
  }

  /* LAYOUT */
  .page {
    max-width: 1060px;
    margin: 0 auto;
    padding: 2.2rem 1.5rem 4rem;
    animation: fadeUp 0.4s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
    margin-bottom: 0;
  }

  @media (max-width: 680px) { .form-grid { grid-template-columns: 1fr; } }

  /* PANELS */
  .panel {
    background: var(--white);
    border: 1px solid var(--grey-200);
    border-radius: 10px;
    padding: 1.5rem;
    box-shadow: 0 1px 4px rgba(11,22,41,0.06);
  }

  .panel-label {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--navy-500);
    font-weight: 500;
    margin-bottom: 1.2rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--grey-200);
  }

  .panel-icon {
    width: 20px; height: 20px;
    background: var(--navy-800);
    border-radius: 5px;
    display: flex; align-items: center; justify-content: center;
    color: var(--orange-lt);
    font-size: 0.7rem;
    flex-shrink: 0;
    border: 1px solid var(--navy-600);
  }

  /* FIELDS */
  .field { margin-bottom: 0.95rem; }
  .field:last-of-type { margin-bottom: 0; }

  .field label {
    display: block;
    font-size: 0.73rem;
    font-weight: 500;
    color: var(--text-lt);
    margin-bottom: 0.3rem;
  }

  .field input,
  .field select {
    width: 100%;
    background: var(--grey-100);
    border: 1.5px solid var(--grey-200);
    border-radius: 7px;
    color: var(--text);
    padding: 0.58rem 0.85rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    outline: none;
    transition: border-color 0.16s, background 0.16s, box-shadow 0.16s;
    -webkit-appearance: none;
    cursor: pointer;
  }

  .field input:focus,
  .field select:focus {
    border-color: var(--navy-500);
    background: var(--white);
    box-shadow: 0 0 0 3px rgba(30,58,95,0.08);
  }

  .field input::placeholder { color: var(--grey-400); }
  select option { background: #fff; color: var(--text); }

  /* ATECO BOX */
  .ateco-box {
    background: var(--navy-800);
    border: 1px solid var(--navy-600);
    border-radius: 7px;
    padding: 0.7rem 0.9rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--grey-500);
    margin-top: 0.5rem;
    min-height: 48px;
    line-height: 1.8;
    transition: all 0.2s;
  }

  .ateco-box .val { color: var(--grey-200); }
  .ateco-box .coeff-hi { color: var(--orange-lt); font-size: 0.95rem; font-weight: 500; }

  /* BUTTON */
  .btn-calc {
    width: 100%;
    background: var(--orange);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0.82rem 1.5rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: background 0.16s, box-shadow 0.16s, transform 0.1s;
    margin-top: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    box-shadow: 0 2px 12px rgba(240,90,26,0.28);
  }

  .btn-calc:hover { background: var(--orange-lt); box-shadow: 0 4px 20px rgba(240,90,26,0.38); }
  .btn-calc:active { transform: scale(0.99); }

  /* RESULTS */
  .results-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
    margin-top: 1.2rem;
  }

  @media (max-width: 680px) { .results-grid { grid-template-columns: 1fr; } }

  .res-card {
    border-radius: 10px;
    padding: 1.4rem;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.32s ease, transform 0.32s ease;
  }

  .res-card.show { opacity: 1; transform: translateY(0); }

  .res-card.startup {
    background: var(--navy-800);
    border: 1px solid var(--navy-600);
    box-shadow: 0 2px 14px rgba(11,22,41,0.18);
  }

  .res-card.regime {
    background: var(--white);
    border: 1px solid var(--grey-200);
    box-shadow: 0 1px 4px rgba(11,22,41,0.06);
  }

  .res-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.1rem;
    padding-bottom: 0.8rem;
  }

  .startup .res-header { border-bottom: 1px solid var(--navy-600); }
  .regime .res-header  { border-bottom: 1px solid var(--grey-200); }

  .phase-tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.57rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    padding: 0.18rem 0.58rem;
    border-radius: 100px;
    font-weight: 500;
  }

  .startup .phase-tag {
    background: rgba(240,90,26,0.18);
    color: var(--orange-lt);
    border: 1px solid rgba(240,90,26,0.32);
  }

  .regime .phase-tag {
    background: var(--grey-100);
    color: var(--navy-500);
    border: 1px solid var(--grey-300);
  }

  .aliq-badge {
    font-family: 'DM Serif Display', serif;
    font-size: 1.1rem;
  }

  .startup .aliq-badge { color: var(--orange-lt); }
  .regime .aliq-badge  { color: var(--navy-500); }

  .res-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.38rem 0;
    gap: 1rem;
  }

  .startup .res-row { border-bottom: 1px solid rgba(255,255,255,0.05); }
  .regime .res-row  { border-bottom: 1px solid var(--grey-100); }
  .res-row:last-child { border-bottom: none !important; }

  .res-row .lbl { font-size: 0.77rem; }
  .startup .res-row .lbl { color: var(--grey-400); }
  .regime .res-row .lbl  { color: var(--text-lt); }

  .res-row .val {
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .startup .res-row .val { color: var(--grey-200); }
  .regime .res-row .val  { color: var(--text); }

  .res-row.tot {
    margin-top: 0.4rem;
    padding-top: 0.9rem;
    border-top: 1.5px solid !important;
  }

  .startup .tot { border-color: var(--navy-500) !important; }
  .regime  .tot { border-color: var(--grey-300) !important; }

  .res-row.tot .lbl { font-weight: 600; font-size: 0.8rem; }
  .startup .tot .lbl { color: var(--white); }
  .regime  .tot .lbl { color: var(--text); }

  .startup .tot .val { color: var(--orange-lt); font-size: 1rem; }
  .regime  .tot .val { color: var(--navy-500); font-size: 1rem; }

  /* SAVING BANNER */
  .saving-banner {
    margin-top: 1.2rem;
    background: var(--navy-800);
    border: 1px solid var(--orange-bd);
    border-radius: 10px;
    padding: 1.2rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.32s 0.22s ease, transform 0.32s 0.22s ease;
    box-shadow: 0 2px 14px rgba(11,22,41,0.15);
  }

  .saving-banner.show { opacity: 1; transform: translateY(0); }

  .saving-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--orange-lt);
    margin-bottom: 0.2rem;
  }

  .saving-desc { font-size: 0.76rem; color: var(--grey-500); }

  .saving-right { text-align: right; }

  .saving-amount {
    font-family: 'DM Serif Display', serif;
    font-size: 1.8rem;
    color: var(--orange-lt);
  }

  .saving-sub {
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    color: var(--grey-500);
    margin-top: 0.05rem;
  }

  /* SECTION HEAD */
  .section-head {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin: 2.4rem 0 1rem;
  }

  .section-head h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.15rem;
    color: var(--navy-800);
    white-space: nowrap;
  }

  .section-line { flex: 1; height: 1px; background: var(--grey-200); }

  /* TABLE */
  .table-wrap {
    background: var(--white);
    border: 1px solid var(--grey-200);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(11,22,41,0.04);
  }

  table { width: 100%; border-collapse: collapse; font-size: 0.79rem; }

  thead th {
    background: var(--navy-800);
    color: var(--grey-400);
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    padding: 0.65rem 1rem;
    text-align: left;
    font-weight: 400;
  }

  tbody tr { transition: background 0.1s; }
  tbody tr:hover td { background: rgba(15,31,61,0.03); }
  tbody tr.hl td { background: rgba(240,90,26,0.05); }

  tbody td {
    padding: 0.58rem 1rem;
    border-bottom: 1px solid var(--grey-100);
    color: var(--text);
    vertical-align: middle;
  }

  tbody tr:last-child td { border-bottom: none; }

  .coeff-badge {
    display: inline-block;
    background: var(--navy-800);
    color: var(--orange-lt);
    border: 1px solid var(--navy-600);
    border-radius: 4px;
    padding: 0.1rem 0.48rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.76rem;
    font-weight: 500;
  }

  .codici-cell {
    font-family: 'DM Mono', monospace;
    font-size: 0.67rem;
    color: var(--grey-500);
  }

  /* NOTE */
  .note {
    margin-top: 1.4rem;
    background: var(--white);
    border: 1px solid var(--grey-200);
    border-left: 3px solid var(--orange);
    border-radius: 8px;
    padding: 0.9rem 1.2rem;
    font-size: 0.74rem;
    color: var(--text-lt);
    line-height: 1.75;
  }

  .note strong {
    color: var(--orange);
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
  }

  @media (max-width: 480px) {
    thead th:nth-child(4), tbody td:nth-child(4) { display: none; }
  }
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-brand">
    <div class="topbar-dot"></div>
    REGIME FORFETTARIO &nbsp;·&nbsp; CALCOLATORE FISCALE &nbsp;·&nbsp; <span style="color:var(--orange-lt)">Realizzato da Studio Punto Diritti</span>
  </div>
  <div class="topbar-pill">2025–2026</div>
</div>

<div class="hero">
  <div class="hero-eyebrow">Partita IVA · Flat Tax</div>
  <h1>Calcola <em>imposta e contributi</em><br>in regime forfettario</h1>
  <p class="hero-sub">Start-up 5% &nbsp;·&nbsp; Regime ordinario 15% &nbsp;·&nbsp; Tutti i codici ATECO</p>
</div>

<div class="page">

  <div class="form-grid">

    <div class="panel">
      <div class="panel-label">
        <div class="panel-icon">€</div>
        Dati reddituali
      </div>

      <div class="field">
        <label>Fatturato lordo annuo previsto (€)</label>
        <input type="number" id="fatturato" placeholder="es. 50.000" min="0" max="85000">
      </div>

      <div class="field">
        <label>Codice ATECO / Categoria attività</label>
        <select id="ateco"><option value="">— Seleziona attività —</option></select>
        <div class="ateco-box" id="atecoInfo">Seleziona un codice ATECO per visualizzare il coefficiente.</div>
      </div>
    </div>

    <div class="panel">
      <div class="panel-label">
        <div class="panel-icon">⚙</div>
        Parametri contributivi
      </div>

      <div class="field">
        <label>Gestione previdenziale</label>
        <select id="gestione">
          <option value="gestione_separata">Gestione Separata INPS — 26,23%</option>
          <option value="artigiani">Artigiani — 24%</option>
          <option value="commercianti">Commercianti — 24,48%</option>
          <option value="altra_cassa">Altra Cassa (esclusa dal calcolo)</option>
        </select>
      </div>

      <div class="field">
        <label>Anno di inizio attività</label>
        <select id="annoInizio">
          <option value="2025">2025</option>
          <option value="2026" selected>2026</option>
          <option value="2026">2026</option>
        </select>
      </div>

      <div class="field">
        <label>Altro reddito imponibile (€) <span style="font-size:0.68rem;font-weight:400;color:var(--grey-400)">dipendente / pensione</span></label>
        <input type="number" id="altroReddito" placeholder="0" min="0" value="0">
      </div>

      <button class="btn-calc" onclick="calcola()">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2"><polygon points="4,2 14,8 4,14"/></svg>
        Calcola
      </button>
    </div>

  </div>

  <!-- RESULTS -->
  <div class="results-grid">
    <div class="res-card startup" id="cardStartup">
      <div class="res-header">
        <span class="phase-tag">Start-Up · Primi 5 anni</span>
        <span class="aliq-badge">5%</span>
      </div>
      <div id="rowsStartup"></div>
    </div>
    <div class="res-card regime" id="cardRegime">
      <div class="res-header">
        <span class="phase-tag">Regime Ordinario · Dal 6° anno</span>
        <span class="aliq-badge">15%</span>
      </div>
      <div id="rowsRegime"></div>
    </div>
  </div>

  <div class="saving-banner" id="savingBanner">
    <div>
      <div class="saving-label">Risparmio fiscale periodo start-up</div>
      <div class="saving-desc">Differenza annua sull'imposta sostitutiva (5% vs 15%)</div>
    </div>
    <div class="saving-right">
      <div class="saving-amount" id="savingAmount"></div>
      <div class="saving-sub">risparmio / anno</div>
    </div>
  </div>

  <!-- TABLE -->
  <div class="section-head">
    <h2>Codici di Redditività ATECO</h2>
    <div class="section-line"></div>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Categoria / Attività</th>
          <th>Codici ATECO</th>
          <th>Coeff. %</th>
          <th>Imponibile su € 50.000</th>
        </tr>
      </thead>
      <tbody id="atecoTableBody"></tbody>
    </table>
  </div>

  <div class="note">
    <strong>NOTE —</strong>
    Limite forfettario: <strong>85.000 €</strong> annui. Riduzione al <strong>5%</strong> per i primi <strong>5 anni</strong> (no esercizio nei 3 anni precedenti).
    INPS Gest. Separata 2025: <strong>26,23%</strong>; Artigiani/Commercianti: ~<strong>24%</strong> con minimale ~4.515 €.
    I contributi sono <strong>deducibili</strong> dall'imponibile prima dell'imposta. Strumento indicativo — consulta il tuo commercialista.
  </div>

</div>

<script>
